<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
               Разбор цветов:
               %gray(...)      - Время будет серым, чтобы не отвлекать
               %magenta(...)   - Название потока будет фиолетовым
               %highlight(...) - Уровень (INFO/ERROR) будет сам менять цвет!
               %cyan(...)      - Имя класса будет голубым
            -->
            <pattern>%gray(%d{HH:mm:ss.SSS}) %magenta([%thread]) %highlight(%-5level) %cyan(%logger{15}) - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>